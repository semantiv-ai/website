---
// Semantiv AI — Coming Soon
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Semantiv AI — Precise semantic infrastructure for adaptive AI systems." />
    <title>Semantiv AI</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="container">
      <div class="content">
        <div class="logo-mark">S</div>
        <h1>Semantiv</h1>
        <p class="tagline">Precise semantic infrastructure for adaptive AI systems.</p>
        <div class="divider"></div>
        <p class="description">
          We build the structural layer that makes AI systems composable, predictable, and precise.
          Where mathematical rigor meets practical intelligence.
        </p>
        <div class="coming-soon">Coming Soon</div>
        <a href="mailto:hello@semantiv.ai" class="email">hello@semantiv.ai</a>
      </div>
      <footer>
        <p>&copy; 2026 Semantiv AI, Inc.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #0a0a0b;
    color: #e4e4e7;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .content {
    text-align: center;
    max-width: 560px;
  }

  .logo-mark {
    width: 64px;
    height: 64px;
    margin: 0 auto 2.5rem;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 600;
    color: white;
    letter-spacing: -0.02em;
  }

  h1 {
    font-size: 3.5rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: #fafafa;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1.125rem;
    font-weight: 400;
    color: #a1a1aa;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .divider {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #6366f1, transparent);
    margin: 0 auto 2rem;
  }

  .description {
    font-size: 1rem;
    font-weight: 300;
    color: #71717a;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .coming-soon {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #6366f1;
    border: 1px solid rgba(99, 102, 241, 0.3);
    padding: 0.5rem 1.5rem;
    border-radius: 100px;
    margin-bottom: 2rem;
  }

  .email {
    display: block;
    font-size: 1rem;
    color: #a1a1aa;
    text-decoration: none;
    transition: color 0.2s;
  }

  .email:hover {
    color: #6366f1;
  }

  footer {
    position: absolute;
    bottom: 2rem;
    text-align: center;
  }

  footer p {
    font-size: 0.8rem;
    color: #3f3f46;
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 2.5rem;
    }
    .tagline {
      font-size: 1rem;
    }
  }
</style>
