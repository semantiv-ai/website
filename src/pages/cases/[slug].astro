---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import RuntimeDiagram from "../../components/RuntimeDiagram.astro";
import { cases } from "../../data/site";
import type { CaseStudy } from "../../data/site";

export function getStaticPaths() {
  return cases.map((caseItem) => ({
    params: { slug: caseItem.slug },
    props: { caseItem }
  }));
}

interface Props {
  caseItem: CaseStudy;
}

const { caseItem } = Astro.props;
---

<Layout title={caseItem.title}>
  <section class="page-hero">
    <div class="shell page-hero__body">
      <div class="page-hero__text">
        <p class="eyebrow">{caseItem.eyebrow}</p>
        <h1 class="headline-xl">{caseItem.title}</h1>
        <p class="lede">{caseItem.scenario}</p>
      </div>
      <div class="page-hero__meta">
        <p>{caseItem.output}</p>
      </div>
    </div>
  </section>

  <section class="section section--paper">
    <div class="shell section-grid">
      <div class="section-label">01 Situation</div>
      <div class="section-body split">
        <div>
          <h2 class="headline-lg">Where Semantiv helps.</h2>
          <p class="lede">{caseItem.where}</p>
          <p class="body-copy">{caseItem.risk}</p>
        </div>
        <RuntimeDiagram title="case flow" steps={caseItem.flow} />
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="shell section-grid">
      <div class="section-label">02 Actions</div>
      <div class="section-body two-column">
        <div>
          <h2 class="headline-md">Example actions</h2>
          <ul class="rule-list">
            {
              caseItem.actions.map((action, index) => (
                <li>
                  <code>{String(index + 1).padStart(2, "0")}</code>
                  <span>{action}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="headline-md">Example gates</h2>
          <ul class="rule-list">
            {
              caseItem.gates.map((gate, index) => (
                <li>
                  <code>{String(index + 1).padStart(2, "0")}</code>
                  <span>{gate}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="shell section-grid">
      <div class="section-label">03 Record</div>
      <div class="section-body split">
        <div>
          <h2 class="headline-lg">Decision record.</h2>
          <p class="lede">{caseItem.productValue}</p>
        </div>
        <div class="artifact-panel">
          <div class="artifact-header">
            <span>Decision record</span>
            <span class={`status ${caseItem.decisionRecord.decision === "Block" ? "status--blocked" : ""}`}>
              {caseItem.decisionRecord.decision}
            </span>
          </div>
          <div class="artifact-body record-body">
            <dl>
              <div>
                <dt>Action</dt>
                <dd>{caseItem.decisionRecord.action}</dd>
              </div>
              <div>
                <dt>Decision</dt>
                <dd>{caseItem.decisionRecord.decision}</dd>
              </div>
              <div>
                <dt>Reason</dt>
                <dd>{caseItem.decisionRecord.reason.join(" ")}</dd>
              </div>
              <div>
                <dt>Outcome</dt>
                <dd>{caseItem.decisionRecord.outcome.join(" ")}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA
    title="Turn one risky workflow into a reviewable control model."
    copy="Use this case shape as a starting point: identify the action, define what it means, attach evidence, find authority, and preserve the decision record."
    secondaryHref="/cases"
    secondaryLabel="Back to cases"
  />
</Layout>

<style>
  .record-body dl {
    display: grid;
    gap: 1rem;
    margin: 0;
  }

  .record-body div {
    display: grid;
    gap: 0.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-dark);
  }

  .record-body div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .record-body dt {
    color: var(--muted-light);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .record-body dd {
    margin: 0;
  }
</style>
