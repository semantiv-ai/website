---
import Logo from "./Logo.astro";
import { navItems } from "../data/site";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(`${href}/`);
};
---

<header class="site-header">
  <div class="shell header-shell">
    <div class="header-top">
      <Logo variant="light" />
      <a class="header-cta" href="/review">Request Review</a>
    </div>
    <nav class="site-nav" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a class={isActive(item.href) ? "active" : ""} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    color: var(--paper);
    background: rgba(15, 13, 13, 0.96);
    border-bottom: 1px solid var(--border-dark);
    backdrop-filter: blur(10px);
  }

  .header-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: center;
    min-height: 4.5rem;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 1rem;
    align-items: center;
    justify-content: flex-end;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .site-nav a {
    color: var(--muted-light);
    text-decoration: none;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--paper);
    text-decoration: underline;
  }

  .header-cta {
    display: inline-flex;
    min-height: 2.25rem;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.65rem;
    border: 1px solid var(--paper);
    border-radius: 2px;
    color: var(--black);
    background: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.1;
    text-decoration: none;
    text-transform: uppercase;
  }

  .header-cta:hover {
    color: var(--paper);
    background: transparent;
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .header-shell {
      grid-template-columns: 1fr;
      gap: 0.65rem;
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }

    .site-nav {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      gap: 0.75rem;
      font-size: 0.72rem;
      scrollbar-width: none;
      white-space: nowrap;
    }

    .site-nav::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 440px) {
    .header-top {
      align-items: center;
      flex-direction: row;
    }

    .header-cta {
      width: auto;
      min-width: 8.5rem;
    }
  }
</style>
