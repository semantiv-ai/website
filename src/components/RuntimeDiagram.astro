---
interface Props {
  steps: string[];
  title?: string;
}

const { steps, title = "controlled workflow" } = Astro.props;
---

<div class="runtime-diagram artifact-panel">
  <div class="artifact-header">
    <span>{title}</span>
    <span class="status">recordable</span>
  </div>
  <div class="artifact-body">
    <ol>
      {
        steps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{step}</strong>
          </li>
        ))
      }
    </ol>
  </div>
</div>

<style>
  .runtime-diagram ol {
    display: grid;
    gap: 0.7rem;
  }

  .runtime-diagram li {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    list-style: none;
  }

  .runtime-diagram li + li {
    padding-top: 0.7rem;
    border-top: 1px solid var(--border-light);
  }

  .section--dark .runtime-diagram li + li,
  .section--black .runtime-diagram li + li {
    border-color: var(--border-dark);
  }

  .runtime-diagram span {
    color: var(--muted-dark);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .section--dark .runtime-diagram span,
  .section--black .runtime-diagram span {
    color: var(--muted-light);
  }

  .runtime-diagram strong {
    min-width: 0;
    font-size: 0.95rem;
    font-weight: 600;
  }
</style>
