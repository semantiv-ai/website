---
const stages = [
  {
    title: "Agent output",
    detail: "tool call, draft, diff, packet"
  },
  {
    title: "Operational meaning",
    detail: "what the work changes"
  },
  {
    title: "Evidence packet",
    detail: "tests, clauses, approvals, traces"
  },
  {
    title: "Authority context",
    detail: "who can allow or escalate"
  },
  {
    title: "Controlled execution",
    detail: "allow, block, escalate, record"
  },
  {
    title: "Decision record",
    detail: "durable explanation"
  }
];
---

<div class="hero-artifact artifact-panel" aria-label="Semantiv runtime artifact">
  <div class="artifact-header">
    <span>Runtime model</span>
    <span class="status">Evidence present</span>
  </div>
  <div class="artifact-body">
    <ol class="pipeline">
      {
        stages.map((stage, index) => (
          <li>
            <span class="pipeline-index">{String(index + 1).padStart(2, "0")}</span>
            <span class="pipeline-copy">
              <strong>{stage.title}</strong>
              <small>{stage.detail}</small>
            </span>
          </li>
        ))
      }
    </ol>
    <div class="decision-strip">
      <span>decision</span>
      <strong>escalate</strong>
      <span>reason</span>
      <strong>authority missing</strong>
    </div>
  </div>
</div>

<style>
  .hero-artifact {
    width: 100%;
  }

  .pipeline {
    display: grid;
    gap: 0;
    counter-reset: flow;
  }

  .pipeline li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: start;
    padding: 0.62rem 0;
    border-bottom: 1px solid var(--border-dark);
    list-style: none;
  }

  .pipeline li:first-child {
    padding-top: 0;
  }

  .pipeline-index,
  .pipeline-copy small {
    color: var(--muted-light);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .pipeline-copy {
    display: grid;
    gap: 0.25rem;
  }

  .pipeline-copy strong {
    font-size: 0.98rem;
    font-weight: 650;
  }

  .decision-strip {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding: 0.65rem;
    border: 1px solid var(--border-dark);
    color: var(--muted-light);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .decision-strip strong {
    color: var(--accent-warning);
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .artifact-header {
      padding: 0.6rem 0.75rem;
    }

    .artifact-body {
      padding: 0.65rem 0.75rem;
    }

    .pipeline {
      display: block;
    }

    .pipeline::before {
      display: block;
      color: var(--muted-light);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1.55;
      content: "agent output -> meaning -> evidence -> control -> record";
    }

    .pipeline li {
      display: none;
    }

    .decision-strip {
      display: none;
    }
  }
</style>
